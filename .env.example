# ── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://tuncauto:tuncauto@localhost:5432/tuncauto?schema=public

# ── Next.js / Auth.js ──────────────────────────────────────────
NODE_ENV=development
AUTH_SECRET=generate-a-strong-random-secret-at-least-32-chars
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ── File Uploads ───────────────────────────────────────────────
# Local dev path; on Railway mount a volume to /app/uploads
UPLOAD_DIR=./uploads

# ── Railway (set in dashboard) ─────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# PORT=3000
