generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VehicleStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum MessageSender {
  ADMIN
  CUSTOMER
}

enum FileType {
  IMAGE
  VIDEO
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  email              String   @unique
  passwordHash       String
  name               String?
  role               UserRole @default(ADMIN)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("users")
}

model HomeMedia {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  type      FileType
  title     String?
  subtitle  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("home_media")
}

model HomeText {
  id        String   @id @default(cuid())
  title     String
  content   String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_text")
}

model About {
  id        String   @id @default("about")
  title     String
  content   String   @db.Text
  imageFile String?
  imageMime String?
  updatedAt DateTime @updatedAt

  @@map("about")
}

model VisionMission {
  id        String   @id @default("vision_mission")
  title     String
  content   String   @db.Text
  imageFile String?
  imageMime String?
  updatedAt DateTime @updatedAt

  @@map("vision_mission")
}

model Vehicle {
  id                 String        @id @default(cuid())
  make               String
  model              String
  year               Int
  price              Decimal       @db.Decimal(12, 2)
  firstRegistration  String?
  mileage            Int?
  fuelType           String?
  transmission       String?
  horsepower         Int?
  engineDisplacement Int?
  exteriorColor      String?
  interiorColor      String?
  upholstery         String?
  doors              String?
  seats              Int?
  color              String?
  description        String?       @db.Text
  financingOffer     String?       @db.Text
  financingUrl       String?
  features           String[]      @default([])
  equipmentFeatures  String[]      @default([])
  status             VehicleStatus @default(AVAILABLE)
  slug               String        @unique
  submissionId       String?       @unique
  submission         SellerSubmission? @relation(fields: [submissionId], references: [id])
  files              FileUpload[]  @relation("VehicleFiles")
  equipment          Equipment[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status, make])
  @@map("vehicles")
}

model Equipment {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int     @default(0)

  @@index([vehicleId, sortOrder])
  @@map("equipment")
}

model SellerSubmission {
  id               String           @id @default(cuid())
  sellerName       String
  sellerEmail      String
  sellerPhone      String
  make             String
  model            String
  year             Int
  price            Decimal?         @db.Decimal(12, 2)
  desiredPrice     Decimal?         @db.Decimal(12, 2)
  mileage          Int?
  fuelType         String?
  transmission     String?
  color            String?
  description      String?          @db.Text
  hasAccident      Boolean?
  accidentDetails  String?          @db.VarChar(200)
  hasRepaint       Boolean?
  repaintDetails   String?          @db.VarChar(200)
  hasPartsReplaced Boolean?
  partsDetails     String?          @db.VarChar(200)
  status           SubmissionStatus @default(PENDING)
  readAt           DateTime?
  adminNotes       String?
  vehicle          Vehicle?
  files            FileUpload[]     @relation("SubmissionFiles")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, createdAt])
  @@map("seller_submissions")
}

model ChatConversation {
  id           String        @id @default(cuid())
  customerName String
  isActive     Boolean       @default(true)
  messages     ChatMessage[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isActive, updatedAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     MessageSender
  senderName     String
  content        String
  isRead         Boolean           @default(false)
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model FileUpload {
  id           String            @id @default(cuid())
  originalName String
  filename     String            @unique
  mimeType     String
  size         Int
  type         FileType
  sortOrder    Int               @default(0)
  vehicleId    String?
  vehicle      Vehicle?          @relation("VehicleFiles", fields: [vehicleId], references: [id], onDelete: SetNull)
  submissionId String?
  submission   SellerSubmission? @relation("SubmissionFiles", fields: [submissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())

  @@map("file_uploads")
}

model Company {
  id            String   @id @default("company")
  name          String
  owner         String   @default("")
  street        String   @default("")
  postalCode    String   @default("")
  city          String   @default("")
  address       String
  phone         String
  email         String
  taxId         String   @default("")
  mapEmbedUrl   String?
  logoFile      String?
  impressum     String   @db.Text
  privacyPolicy String   @db.Text
  updatedAt     DateTime @updatedAt

  @@map("company")
}

model SocialLink {
  id       String         @id @default(cuid())
  platform SocialPlatform @unique
  url      String         @default("")
  isActive Boolean        @default(false)

  @@map("social_links")
}
